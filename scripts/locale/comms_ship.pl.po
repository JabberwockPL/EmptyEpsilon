#: scripts/comms_ship.lua:39
msgctxt "shipAssist-comms"
msgid "What do you want?"
msgstr "Czego chcecie?"

#: scripts/comms_ship.lua:41
msgctxt "shipAssist-comms"
msgid "Sir, how can we assist?"
msgstr "Jak możemy pomóc?"

#: scripts/comms_ship.lua:44
msgctxt "shipAssist-comms"
msgid "Defend a waypoint"
msgstr "Brońcie punktu nawigacyjnego"

#: scripts/comms_ship.lua:47
msgctxt "shipAssist-comms"
msgid "No waypoints set. Please set a waypoint first."
msgstr "Nie wyznaczono punktów nawigacyjnych. Najpierw wyznacz punkt nawigacyjny."

#: scripts/comms_ship.lua:48 scripts/comms_ship.lua:58
#: scripts/comms_ship.lua:71 scripts/comms_ship.lua:79
#: scripts/comms_ship.lua:89
msgid "Back"
msgstr "Wstecz"

#: scripts/comms_ship.lua:50
msgctxt "shipAssist-comms"
msgid "Which waypoint should we defend?"
msgstr "Którego punktu nawigacyjnego mamy bronić?"

#: scripts/comms_ship.lua:53
#, lua-format
msgctxt "shipAssist-comms"
msgid "Defend %s"
msgstr "Brońcie %s"

#: scripts/comms_ship.lua:57
#, lua-format
msgctxt "shipAssist-comms"
msgid "We are heading to assist at %s."
msgstr "Ruszamy, by udzielić pomocy przy %s."

#: scripts/comms_ship.lua:67
msgctxt "shipAssist-comms"
msgid "Assist me"
msgstr "Pomóżcie mi"

#: scripts/comms_ship.lua:69
msgctxt "shipAssist-comms"
msgid "Heading toward you to assist."
msgstr "Ruszamy w twoim kierunku, aby udzielić pomocy."

#: scripts/comms_ship.lua:76
msgctxt "shipAssist-comms"
msgid "Report status"
msgstr "Raportuj stan"

#: scripts/comms_ship.lua:85
#, lua-format
msgctxt "shipAssist-comms"
msgid "Dock at %s"
msgstr "Zadokujcie do stacji %s"

#: scripts/comms_ship.lua:87
#, lua-format
msgctxt "shipAssist-comms"
msgid "Docking at %s."
msgstr "Dokowanie do stacji %s."

#: scripts/comms_ship.lua:106
msgctxt "shipEnemy-comms"
msgid "We will see to your destruction!"
msgstr "Zrobimy wszystko, by was zniszczyć!"

#: scripts/comms_ship.lua:107
msgctxt "shipEnemy-comms"
msgid "Your bloodline will end here!"
msgstr "Tutaj kończy się wasza dynastia!"

#: scripts/comms_ship.lua:108
msgctxt "shipEnemy-comms"
msgid "Your feeble threats are meaningless."
msgstr "Wasze marne groźby są bez znaczenia."

#: scripts/comms_ship.lua:110
msgctxt "shipEnemy-comms"
msgid ""
"Ktzzzsss.\n"
"\n"
"You will DIEEee weaklingsss!"
msgstr "Kzzzssszzz.\n\nZGINIECIE, ssssłabeusze!"

#: scripts/comms_ship.lua:114
msgctxt "shipEnemy-comms"
msgid ""
"We wish you no harm, but will harm you if we must.\n"
"\n"
"End of transmission."
msgstr "Nie mamy zamiaru was skrzywdzić, ale zrobimy to, gdy będzie to konieczne.\n\nKoniec transmisji."

#: scripts/comms_ship.lua:118
msgctxt "shipEnemy-comms"
msgid "Stay out of our way, or your death will amuse us extremely!"
msgstr "Nie wchodźcie nam w drogę, albo ubawimy się waszą śmiercią!"

#: scripts/comms_ship.lua:120
msgctxt "shipEnemy-comms"
msgid ""
"One zero one.\n"
"\n"
"No binary communication detected. Switching to universal speech.\n"
"\n"
"Generating appropriate response for target from human language archives.\n"
"\n"
":Do not cross us.:\n"
"\n"
"Communication halted."
msgstr "Jeden zero jeden.\n\nNie wykryto komunikacji binarnej. Przełączam się na mowę uniwersalną.\n\nTworzę odpowiedź na podstawie archiwów mowy ludzkiej.\n\nNie zadzierajcie z nami.\n\nKoniec komunikacji."

#: scripts/comms_ship.lua:129
msgctxt "shipEnemy-comms"
msgid "EXECUTE: SELFDESTRUCT"
msgstr "WYKONAĆ: AUTODESTRUKCJA"

#: scripts/comms_ship.lua:130
msgctxt "shipEnemy-comms"
msgid "Rogue command received. Targeting source."
msgstr "Wykryto niedozwoloną komendę. Namierzamy źródło."

#: scripts/comms_ship.lua:131
msgctxt "shipEnemy-comms"
msgid "External command ignored."
msgstr "Komenda zewnętrzna zignorowana."

#: scripts/comms_ship.lua:133
msgctxt "shipEnemy-comms"
msgid ""
"The hive suffers no threats. Opposition to any of us is opposition to us "
"all.\n"
"\n"
"Stand down or prepare to donate your corpses toward our nutrition."
msgstr "Rój nie znosi gróźb. Kto jest przeciwko jednemu z nas, jest przeciw nam wszystkim.\n\nWycofajcie się, albo przygotujcie się, by wasze ciała posłużyły nam za karmę."

#: scripts/comms_ship.lua:136
msgctxt "shipEnemy-comms"
msgid "<Transmits 'The Itsy-Bitsy Spider' on all wavelengths>"
msgstr "<Transmituje <Wlazł kotek> na wszystkich częstotliwościach>"

#: scripts/comms_ship.lua:137
msgctxt "shipEnemy-comms"
msgid "We do not need permission to pluck apart such an insignificant threat."
msgstr "Nie potrzebujemy pozwolenia, żeby rozbić w puch takie nic."

#: scripts/comms_ship.lua:138
msgctxt "shipEnemy-comms"
msgid "The hive has greater priorities than exterminating pests."
msgstr "Rój ma ważniejsze priorytety, niż eksterminacja szkodników."

#: scripts/comms_ship.lua:140
msgctxt "shipEnemy-comms"
msgid "Mind your own business!"
msgstr "Zajmijcie się swoimi sprawami!"

#: scripts/comms_ship.lua:168
msgctxt "ship-comms"
msgid ""
"Sorry, we have no time to chat with you.\n"
"\n"
"We are on an important mission."
msgstr "Przepraszamy, nie mamy czasu na pogawędki.\n\nWykonujemy ważną misję."

#: scripts/comms_ship.lua:172
msgctxt "ship-comms"
msgid ""
"We have nothing for you.\n"
"\n"
"Good day."
msgstr "Nic dla was nie mamy.\n\nMiłego dnia."

#: scripts/comms_ship.lua:187
#, lua-format
msgctxt "shipAssist-comms"
msgid "Hull: %d%%\n"
msgstr "Kadłub: %d%%\n"

#: scripts/comms_ship.lua:191
#, lua-format
msgctxt "shipAssist-comms"
msgid "Shield: %d%%\n"
msgstr "Tarcza: %d%%\n"

#: scripts/comms_ship.lua:193
#, lua-format
msgctxt "shipAssist-comms"
msgid "Front Shield: %d%%\n"
msgstr "Tarcza przednia: %d%%\n"

#: scripts/comms_ship.lua:194
#, lua-format
msgctxt "shipAssist-comms"
msgid "Rear Shield: %d%%\n"
msgstr "Tarcza tylna: %d%%\n"

#: scripts/comms_ship.lua:197
#, lua-format
msgctxt "shipAssist-comms"
msgid "Shield %d: %d%%\n"
msgstr "Shield %d: %d%%\n"

#: scripts/comms_ship.lua:203
#, lua-format
msgctxt "shipAssist-comms"
msgid "%s Missiles: %d/%d\n"
msgstr "Pociski: %s – %d/%d\n"

#: scripts/comms_ship.lua:215
#, lua-format
msgctxt "shipAssist-comms"
msgid "WP %d"
msgstr "PN %d"
